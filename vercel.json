{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/solar_api/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/solar_api/wsgi.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "backend/solar_api/wsgi.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "backend/solar_api/wsgi.py"
    },
    {
      "source": "/media/(.*)",
      "destination": "backend/solar_api/wsgi.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "frontend/assets/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "frontend/images/$1"
    },
    {
      "source": "/vite.svg",
      "destination": "frontend/vite.svg"
    },
    {
      "source": "/((?!assets|images|vite.svg|api|admin|static|media).*)",
      "destination": "frontend/index.html"
    }
  ]
}
