{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/solar_api/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/solar_api/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "backend/solar_api/wsgi.py" },
    { "src": "/static/(.*)", "dest": "backend/solar_api/wsgi.py" },
    { "src": "/media/(.*)", "dest": "backend/solar_api/wsgi.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/vite.svg", "dest": "/vite.svg" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
